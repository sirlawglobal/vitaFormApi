# ============================================================
# VITAFOAM MOBILE COMMERCE PLATFORM — Environment Variables
# ============================================================
# Copy this file to .env and fill in all values
# NEVER commit .env to version control

# ── App ──────────────────────────────────────────────────────
APP_NAME=Vitafoam Backend
APP_ENV=development           # development | staging | production
APP_PORT=3000
APP_URL=http://localhost:3000
APP_VERSION=1.0.0
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb://vitaform:vitaform_secret@localhost:27017/vitaform?authSource=admin
MONGODB_DB_NAME=vitaform
# Production: mongodb+srv://user:pass@cluster.mongodb.net/vitaform

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=vitaform:
# Production: use Redis Cluster or Redis Sentinel URL
# REDIS_URL=redis://:password@host:6379

# ── Session ──────────────────────────────────────────────────
SESSION_TTL_SECONDS=604800         # 7 days
SESSION_MAX_DEVICES=5

# ── BullMQ ───────────────────────────────────────────────────
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=
BULL_REDIS_DB=1

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URI=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=vitaform.domain.events
RABBITMQ_DLX=vitaform.dead.letter
RABBITMQ_PREFETCH=10

# ── Storage (Cloudinary) ─────────────────────────────────────
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STORAGE_MAX_FILE_SIZE_MB=10
STORAGE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ── Email (Brevo / SendGrid / SMTP) ──────────────────────────
EMAIL_PROVIDER=brevo               # brevo | sendgrid | smtp
EMAIL_FROM=noreply@vitafoam.com.ng
EMAIL_FROM_NAME=Vitafoam
BREVO_API_KEY=
SENDGRID_API_KEY=
# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── SMS (Termii) ─────────────────────────────────────────────
SMS_PROVIDER=termii
TERMII_API_KEY=
TERMII_SENDER_ID=Vitafoam

# ── Firebase (FCM) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or use service account JSON path:
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ── AI Provider ──────────────────────────────────────────────
AI_PROVIDER=grok                   # grok | openai | gemini
GROK_API_KEY=
GROK_MODEL=grok-2-latest
GROK_BASE_URL=https://api.x.ai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# ── Payment Providers ────────────────────────────────────────
PAYMENT_PROVIDER=paystack          # paystack | flutterwave | moniepoint
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-
FLUTTERWAVE_WEBHOOK_SECRET=
MONIEPOINT_API_KEY=
MONIEPOINT_WEBHOOK_SECRET=

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000            # 1 minute window
RATE_LIMIT_MAX=100                 # requests per window
RATE_LIMIT_AUTH_MAX=10             # stricter for auth routes

# ── Outbox Worker ────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=5000       # 5 seconds
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                     # trace | debug | info | warn | error
LOG_PRETTY=true                    # false in production

# ── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true               # false in production
SWAGGER_PATH=docs
SWAGGER_TITLE=Vitafoam API
SWAGGER_DESCRIPTION=Vitafoam Mobile Commerce Platform API

# ── SMTP / Email (Nodemailer) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@vitafoam.com
